generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                     String                  @id @default(cuid())
  walletAddress          String                  @unique
  displayName            String?
  email                  String?
  avatarUrl              String?
  circleWalletId         String?                 @unique
  circleWalletAddress    String?                 @unique
  circleWalletBlockchain CircleWalletBlockchain?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  chats                  Chat[]
  trades                 Trade[]
  transactions           Transaction[]

  @@index([createdAt])
}

model Chat {
  id           String        @id @default(cuid())
  userId       String
  title        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     Message[]
  trades       Trade[]
  transactions Transaction[]

  @@index([userId, createdAt])
}

model Message {
  id        String        @id @default(cuid())
  chatId    String
  role      MessageRole
  content   String
  status    MessageStatus @default(COMPLETED)
  createdAt DateTime      @default(now())
  chat      Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model Transaction {
  id                String              @id @default(cuid())
  userId            String
  chatId            String?
  walletAddress     String
  amountUsd         Decimal
  currency          String
  provider          TransactionProvider
  externalPaymentId String?
  status            TransactionStatus   @default(PENDING)
  metadata          Json?
  createdAt         DateTime            @default(now())
  chat              Chat?               @relation(fields: [chatId], references: [id])
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([chatId])
  @@index([walletAddress])
}

model Trade {
  id            String         @id @default(cuid())
  userId        String
  chatId        String?
  transactionId String?
  direction     TradeDirection
  tokenSymbol   String
  tokenAddress  String
  tokenAmount   String
  priceUsdEach  String
  walletAddress String
  txHash        String?
  status        TradeStatus    @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  chat          Chat?          @relation(fields: [chatId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([chatId])
}

enum CircleWalletBlockchain {
  ARC_TESTNET
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TransactionProvider {
  CIRCLE
  X402
  MANUAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TradeDirection {
  BUY
  SELL
}

enum TradeStatus {
  PENDING
  COMPLETED
  FAILED
}
